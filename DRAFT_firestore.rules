rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isValidDashboard(data) {
      return data.ownerId is string && data.ownerId.size() <= 128 &&
             data.sales is string && data.sales.size() <= 1048000 &&
             (data.createdAt == request.time) &&
             (!('adsSpend' in data) || data.adsSpend is number);
    }
    
    match /dashboards/{dashboardId} {
      allow read, write: if true;
    }
  }
}
